{
    "name": "sockeon/mcp",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sockeon\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sockeon\\Mcp\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "xentixar",
            "email": "xentixar@gmail.com"
        }
    ],
    "require": {
        "mcp/sdk": "dev-main",
        "symfony/finder": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
