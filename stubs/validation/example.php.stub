use Sockeon\Sockeon\Validation\Validator;
use Sockeon\Sockeon\Exception\Validation\ValidationException;

#[SocketOn('user.register')]
public function handleUserRegister(string $clientId, array $data): void
{
    $validator = new Validator();
    try {
        $validator->validate($data, [
            'name' => ['required', 'string'],
            'email' => ['required', 'email'],
        ]);
    } catch (ValidationException $exception) {
        $this->emit($clientId, 'error', [
            'errors' => $exception->getErrors()
        ]);
        return;
    }

    // Process valid data
}

